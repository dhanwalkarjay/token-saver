# ──────────────────────────────────────────────────────────────────────────
# TokenSaver Enterprise – Environment Configuration
# Copy this file to .env and fill in your actual values.
# ──────────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────────────
APP_NAME=TokenSaver Enterprise
VERSION=1.0.0
DEBUG=false
HOST=0.0.0.0
PORT=8000

# ── Security ──────────────────────────────────────────────────────────────
# IMPORTANT: Change this before deploying to production!
MASTER_API_KEY=ts-master-changeme-replace-this

# Comma-separated or JSON array of allowed CORS origins
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8080"]

# ── Redis ─────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_VECTOR_DIM=384
CACHE_SIMILARITY_THRESHOLD=0.85
CACHE_TTL_SECONDS=86400

# ── PostgreSQL ────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://tokensaver:password@localhost:5432/tokensaver

# ── Embedding model ───────────────────────────────────────────────────────
# Runs locally – no external calls. First run will download from HuggingFace.
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# ── LLM Provider API Keys ─────────────────────────────────────────────────
# Add only the providers you intend to use.

OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=AIza...
MISTRAL_API_KEY=...
COHERE_API_KEY=...

# AWS Bedrock (optional)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# Azure OpenAI (optional)
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=

# ── Model Routing ─────────────────────────────────────────────────────────
TIER1_MAX_TOKENS=200
TIER2_MAX_TOKENS=1000

# ── Compression ───────────────────────────────────────────────────────────
COMPRESSION_ENABLED=true
COMPRESSION_THRESHOLD_TOKENS=2000
COMPRESSION_RATIO=0.4

# ── Rate Limiting ─────────────────────────────────────────────────────────
RATE_LIMIT_REQUESTS_PER_MINUTE=60
